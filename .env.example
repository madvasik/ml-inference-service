# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ml_service
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ml_service

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Billing
PREDICTION_COST=10

# Application
DEBUG=True
API_V1_PREFIX=/api/v1
ML_MODELS_DIR=var/ml_models
INITIAL_ADMIN_EMAIL=admin@admin.com
# With DEBUG=True, short passwords are allowed (e.g. admin). In production use DEBUG=False and a strong password (≥12 chars).
INITIAL_ADMIN_PASSWORD=admin
INITIAL_ADMIN_CREDITS=10000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_USER_PER_MINUTE=100
# Trust X-Forwarded-For / X-Real-IP when behind a reverse proxy (rate limiting client IP)
TRUSTED_PROXY_HEADERS=False

# Celery worker: Prometheus multiprocess dir (optional; defaults to /tmp or PROMETHEUS_MULTIPROC_DIR)
PROMETHEUS_MULTIPROC_DIR=

# Shared secret so Prometheus can scrape GET /metrics without a JWT (must match in docker-compose Prometheus)
PROMETHEUS_SCRAPE_TOKEN=dev-prometheus-scrape-token-change-me-in-production-min-32

# CORS (для production указать конкретные домены через запятую)
CORS_ORIGINS=*

# File Upload
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_JSON_FORMAT=False
